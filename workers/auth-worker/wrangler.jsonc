/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "aiagents-hub-auth-worker",
	"main": "src/index.ts",
	"compatibility_date": "2025-04-01",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"rules": [
		{
			"type": "Text",
			"globs": ["**/*.md"],
			"fallthrough": true
		}
	],
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": [
				"BroadcastServiceDO",
				"UserShardDO",
				"UserDO"
			]
		},
		{
			"tag": "v2",
			"new_sqlite_classes": []
		},
		{
			"tag": "v3",
			"deleted_classes": []
		}
	],
	"durable_objects": {
		"bindings": [
			{
				"name": "BROADCAST_SERVICE_DO",
				"script_name": "aiagents-hub-auth-worker",
				"class_name": "BroadcastServiceDO"
			},
			{
				"name": "USER_SHARD_DO", 
				"script_name": "aiagents-hub-auth-worker",
				"class_name": "UserShardDO"
			},
			{
				"name": "USER_DO",
				"script_name": "aiagents-hub-auth-worker", 
				"class_name": "UserDO"
			}
		]
	},
	"observability": {
		"enabled": true
	},
	"images": {
		"binding": "IMAGES" // i.e. available in your Worker on env.IMAGES
	},
	// "placement": { "mode": "smart" }
	"vars": {
		"ACCOUNT_ID": "e76b7bb989f93985402e1a61e6cd5ff3",  
		"SMS_FROM_NUMBER": "+84919358683",		
		"SIWE_DOMAIN": "aiagents-hub.vn",
		"FRONTEND_URL": "https://aiagents-hub.vn",
		"BASE_URL": "https://api.aiagents-hub.vn",
		"DEBUG": "false",
		"ENVIRONMENT": "production",
		"QUEUE_BATCH_SIZE": "100",
		"QUEUE_FLUSH_THRESHOLD": "200",
		"QUEUE_FLUSH_INTERVAL": "5000",
		"MAX_SEND_FAILURE_COUNT": "3",
		"RETRY_ALARM_INTERVAL": "60000",
		"ADMIN_IDENTIFIERS": "tuanta2021@gmail.com",
		"PRIMARY_ADMIN_IDENTIFIER": "tuanta2021@gmail.com",
		"TURNSTILE_SITE_KEY": "0x4AAAAAADXOWPMRtW0XIcLk",
	},
	// ========== QUEUE CONFIGURATION ==========
	"queues": {
		"producers": [
		{
			"binding": "INPUT_QUEUE",
			"queue": "aiagents-hub-input-part-0"
		},
		{
			"binding": "ERROR_QUEUE",
			"queue": "aiagents-hub-error-queue-dlq"
		},
		{
			"binding": "WS_BROADCAST_QUEUE",
			"queue": "aiagents-hub-ws-broadcast-queue"
		}
		]
	},

	"d1_databases": [
		{
			"binding": "D1DB",
			"database_name": "aiagents-hub-db",
			"database_id": "1c4b5c9d-4125-44fc-b1c8-c47bd3898b54"
		}
	],
	"r2_buckets": [
		{
		"binding": "R2_VERSION_BUCKET",
		"bucket_name": "aiagents-hub-version-backup-bucket"
		},
		{
		"binding": "R2_EKYC_BUCKET",
		"bucket_name": "aiagents-hub-ekyc-storage-bucket"
		}
	],	
	"kv_namespaces": [
		{
			"binding": "NONCE_KV",
			"id": "dfbfc6ec8f75482bbf54854d86442e27"
		},
		{
			"binding": "SYSTEM_CONFIG_KV",
			"id": "e80315e1a3fb47e2959d645a15ac534a"
		}
	],
	"ai": {
		"binding": "AI"  
	},
	"routes": [
		{
		"pattern": "api.aiagents-hub.vn",
		"custom_domain": true
		}
	],	
  	"secrets_store_secrets": [
		{
		"binding": "JWT_SECRET",
		"store_id": "8fe9cf5e23574e849953a38dcdafdf8c",
		"secret_name": "JWT_SECRET"
		},
		{
		"binding": "EMAIL_API_KEY",
		"store_id": "8fe9cf5e23574e849953a38dcdafdf8c",
		"secret_name": "EMAIL_API_KEY"
		},
		{
		"binding": "BREVO_API_KEY",
		"store_id": "8fe9cf5e23574e849953a38dcdafdf8c",
		"secret_name": "BREVO_API_KEY"
		},
		{
		"binding": "TWILIO_ACCOUNT_SID",
		"store_id": "8fe9cf5e23574e849953a38dcdafdf8c",
		"secret_name": "TWILIO_ACCOUNT_SID"
		},	
		{
		"binding": "TWILIO_AUTH_TOKEN",
		"store_id": "8fe9cf5e23574e849953a38dcdafdf8c",
		"secret_name": "TWILIO_AUTH_TOKEN"
		},	
		{
		"binding": "VONAGE_API_SECRET",
		"store_id": "8fe9cf5e23574e849953a38dcdafdf8c",
		"secret_name": "VONAGE_API_SECRET"
		},	
		{
		"binding": "VONAGE_API_KEY",
		"store_id": "8fe9cf5e23574e849953a38dcdafdf8c",
		"secret_name": "VONAGE_API_KEY"
		},	
		{
		"binding": "VONAGE_AUTH_TOKEN",
		"store_id": "8fe9cf5e23574e849953a38dcdafdf8c",
		"secret_name": "VONAGE_AUTH_TOKEN"
		},
		{
		"binding": "ENCRYPTION_SECRET",
		"store_id": "8fe9cf5e23574e849953a38dcdafdf8c",
		"secret_name": "ENCRYPTION_SECRET"
		},	
		{
		"binding": "GOOGLE_CLIENT_ID",
		"store_id": "8fe9cf5e23574e849953a38dcdafdf8c",
		"secret_name": "GOOGLE_CLIENT_ID"
		},	
		{
		"binding": "GOOGLE_CLIENT_SECRET",
		"store_id": "8fe9cf5e23574e849953a38dcdafdf8c",
		"secret_name": "GOOGLE_CLIENT_SECRET"
		},	
		{
		"binding": "APPLE_CLIENT_ID",
		"store_id": "8fe9cf5e23574e849953a38dcdafdf8c",
		"secret_name": "APPLE_CLIENT_ID"
		},
		{
		"binding": "APPLE_CLIENT_SECRET",
		"store_id": "8fe9cf5e23574e849953a38dcdafdf8c",
		"secret_name": "APPLE_CLIENT_SECRET"
		},
		{
		"binding": "FACEBOOK_CLIENT_ID",
		"store_id": "8fe9cf5e23574e849953a38dcdafdf8c",
		"secret_name": "FACEBOOK_CLIENT_ID"
		},
		{
		"binding": "FACEBOOK_CLIENT_SECRET",
		"store_id": "8fe9cf5e23574e849953a38dcdafdf8c",
		"secret_name": "FACEBOOK_CLIENT_SECRET"
		},
		{
		"binding": "GITHUB_CLIENT_ID",
		"store_id": "8fe9cf5e23574e849953a38dcdafdf8c",
		"secret_name": "GITHUB_CLIENT_ID"
		},	
		{
		"binding": "GITHUB_CLIENT_SECRET",
		"store_id": "8fe9cf5e23574e849953a38dcdafdf8c",
		"secret_name": "GITHUB_CLIENT_SECRET"
		},
		{
		"binding": "TWITTER_CLIENT_ID",
		"store_id": "8fe9cf5e23574e849953a38dcdafdf8c",
		"secret_name": "TWITTER_CLIENT_ID"
		},
		{
		"binding": "TWITTER_CLIENT_SECRET",
		"store_id": "8fe9cf5e23574e849953a38dcdafdf8c",
		"secret_name": "TWITTER_CLIENT_SECRET"
		},
		{
		"binding": "CF_AI_API_TOKEN",
		"store_id": "8fe9cf5e23574e849953a38dcdafdf8c",
		"secret_name": "CF_AI_API_TOKEN"
		},
		{
		"binding": "VIETQR_ACCOUNT_NO",
		"store_id": "8fe9cf5e23574e849953a38dcdafdf8c",
		"secret_name": "VIETQR_ACCOUNT_NO"
		},
		{
		"binding": "VIETQR_ACCOUNT_NAME",
		"store_id": "8fe9cf5e23574e849953a38dcdafdf8c",
		"secret_name": "VIETQR_ACCOUNT_NAME"
		},
		{
		"binding": "VIETQR_ACQ_ID",
		"store_id": "8fe9cf5e23574e849953a38dcdafdf8c",
		"secret_name": "VIETQR_ACQ_ID"
		},
		{
		"binding": "CASSO_WEBHOOK_CHECKSUM_KEY",
		"store_id": "8fe9cf5e23574e849953a38dcdafdf8c",
		"secret_name": "CASSO_WEBHOOK_CHECKSUM_KEY"
		},
		{
		"binding": "TURNSTILE_SECRET_KEY",
		"store_id": "8fe9cf5e23574e849953a38dcdafdf8c",
		"secret_name": "TURNSTILE_SECRET_KEY"
		}
	],
  	"services": [
		{
			"binding": "QUEUE_WORKER",        // Tên bạn sẽ dùng trong code: env.QUEUE_WORKER
			"service": "aiagents-hub-queue-worker"        // Tên chính xác của Worker kia (phải khớp 100%)
		}
	]
}