/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "aiagents-hub-queue-worker",
	"main": "src/index.ts",
	"compatibility_date": "2025-12-05",
	"workers_dev": false,                // Tắt hoàn toàn subdomain *.workers.dev
  "preview_urls": false,               // Tắt preview URL (không ai có thể truy cập qua preview)
	"observability": {
		"enabled": true
	},
// ========== ENVIRONMENT VARIABLES ==========
  "define": {
    "ENVIRONMENT": "production",
    "BATCH_SIZE": "100",
    "MAX_RETRIES": "3",
    "AE_BATCH_SIZE": "1000",
    "QUEUE_PROCESSING_TIMEOUT": "30000"
  },

  // ========== QUEUE CONFIGURATION ==========
  "queues": {
    "producers": [
      {
        "binding": "INPUT_QUEUE",
        "queue": "aiagents-hub-input-part-0"
      },
      {
        "binding": "ERROR_QUEUE",
        "queue": "aiagents-hub-error-queue-dlq"
      }
    ],
    "consumers": [
      {
        "queue": "aiagents-hub-input-part-0",
        "max_batch_size": 100,
        "max_batch_timeout": 10,
        "max_retries": 3,
        "dead_letter_queue": "aiagents-hub-error-queue-dlq",
        "retry_delay": 5
      },
      {
        "queue": "aiagents-hub-error-queue-dlq",
        "max_batch_size": 50,
        "max_batch_timeout": 30,
        "max_retries": 1,
        "retry_delay": 10
      }
    ]
  },

  // ========== DURABLE OBJECTS BINDING ==========
  "durable_objects": {
    "bindings": [
      {
        "name": "USER_DO",
				"class_name": "UserDO",
        "script_name": "aiagents-hub-auth-worker"
      }
    ]
  },

  // ========== ANALYTICS ENGINE ==========
  "analytics_engine_datasets": [
    {
      "binding": "AE_DATASET",
      "dataset": "aiagents-hub-queue-analytics"
    }
  ],
	"d1_databases": [
    {
      "binding": "D1DB",
      "database_name": "aiagents-hub-db",
      "database_id": "02704177-c811-4132-92e4-622f955a7ae8",
      "migrations_dir": "migrations"
    }
  ],
	"kv_namespaces": [
    {
      "binding": "SYSTEM_CONFIG_KV",
      "id": "529353fcfe7641c9bcbd5dda5d01d5da"
    }
  ]
}
